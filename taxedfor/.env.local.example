# ─── Required: Claude fallback W2 parsing ────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Optional: AWS Textract for privacy-first W2 processing ──────────────────
# When these are set, Textract is used instead of Claude for W2 parsing.
# No personal tax data is sent to any LLM — fully privacy-preserving.
#
# To enable on Vercel:
#   1. Go to your project → Settings → Environment Variables
#   2. Add AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, and AWS_REGION
#   3. Redeploy — the app automatically switches to the Textract path
#
# IAM permissions needed: textract:AnalyzeDocument
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
